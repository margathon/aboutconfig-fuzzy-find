{
  "manifest_version": 2,
  "name": "About Config Fuzzy Finder",
  "version": "1.0.0",
  "description": "Fuzzy-search preference names and open about:config or copy a name.",
  "browser_specific_settings": {
    "gecko": {
      "id": "aboutconfig-fuzzy-find@local",
      "strict_min_version": "109.0"
    }
  },
  "browser_action": {
    "default_title": "About Config Fuzzy Finder",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Open pref fuzzy finder"
    }
  },
  "permissions": ["tabs", "clipboardWrite"]
}
